# Python
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/
.eggs/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/

# Virtual envs
.venv/
venv/
env/

# Editor / OS
.vscode/
.idea/
*.swp
.DS_Store

# Local tool settings
.claude/

# Generated example output
examples/**/*.html
examples/**/*.svg
examples/**/*_out/
examples/**/out/

# Scratch / verification artifacts (test hunt files, screenshots, server logs).
# Lives in-repo so nothing is ever written outside the project; contents are ignored
# but the folder is kept via .gitkeep.
/tmp/*
!/tmp/.gitkeep
